local function getEquippedGun()
    local char = LocalPlayer.Character
    if not char then return nil end
    local children = char:GetChildren()
    for i = 1,#children do
        local t = children[i]
        if t:IsA("Tool") and t:FindFirstChild("ConfigGun") then
            return t
        end
    end
    return nil
end

