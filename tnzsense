            btn.AutoButtonColor = false
            btn.Parent = container
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 4)
            btnCorner.Parent = btn
        end
    end
    
    -- Обновляем размер главного фрейма
    if mainFrame then
        local newHeight = 30 + (activeCount * 26)
        mainFrame.Size = UDim2.new(0, 200, 0, math.max(40, newHeight))
    end
end

-- Функция регистрации кейбинда
local function RegisterKeybind(key, name)
    if not key or key == "" then return end
    
    if not ActiveKeybinds[key] then
        ActiveKeybinds[key] = {name = name, isPressed = false, connection = nil}
    end
    
    -- Если уже есть connection, отключаем его
    if ActiveKeybinds[key].connection then
        for _, conn in ipairs(ActiveKeybinds[key].connection) do
            if conn then conn:Disconnect() end
        end
    end
    
    local keyCode = Enum.KeyCode[key]
    if not keyCode then return end
    
    -- Отслеживаем нажатие клавиши
    local inputBegan = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == keyCode then
            if not ActiveKeybinds[key].isPressed then
                ActiveKeybinds[key].isPressed = true
                UpdateKeybindDisplay()
            end
        end
    end)
    
    -- Отслеживаем отпускание клавиши
    local inputEnded = UserInputService.InputEnded:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == keyCode then
            if ActiveKeybinds[key].isPressed then
                ActiveKeybinds[key].isPressed = false
                UpdateKeybindDisplay()
            end
        end
    end)
    
    -- Сохраняем connection для очистки
    ActiveKeybinds[key].connection = {inputBegan, inputEnded}
end

-- Функция очистки всех кейбиндов
local function ClearAllKeybinds()
    for key, data in pairs(ActiveKeybinds) do
        if data.connection then
            for _, conn in ipairs(data.connection) do
                if conn then conn:Disconnect() end
            end
        end
    end
    ActiveKeybinds = {}
end

-- Функция получения значения кейбинда из Rayfield (исправлено)
local function GetKeybindValue(flagName)
    local success, result = pcall(function()
        return Rayfield:GetFlag(flagName)
    end)
    if success and result then
        return result
    end
    return ""
end

-- Функция обновления списка кейбиндов из Rayfield
local function UpdateKeybindsFromRayfield()
    if not KeybindIndicatorEnabled then return end
    
    -- Очищаем старые
    ClearAllKeybinds()
    
    -- Aim Lock Keybind
    local aimlockKey = GetKeybindValue("AimLockKeybind")
    if aimlockKey and aimlockKey ~= "" then
        RegisterKeybind(aimlockKey, "Aim Lock")
    end
    
    -- Teleport Keybind
    local teleportKey = GetKeybindValue("TeleportKeybind")
    if teleportKey and teleportKey ~= "" then
        RegisterKeybind(teleportKey, "TP 500 Up")
    end
    
    -- Teleport To Player Keybind
    local tpPlayerKey = GetKeybindValue("TeleportToPlayerKeybind")
    if tpPlayerKey and tpPlayerKey ~= "" then
        RegisterKeybind(tpPlayerKey, "TP To Player")
    end
end

