-- Bullet Tracer
local BulletTracerEnabled = false
local BulletTracerColor = Color3.fromRGB(0, 255, 255)
local TracerConnection = nil
local OriginalColors = {}

local function ChangeTracer(part)
    if not BulletTracerEnabled then return end
    if part.Name == "tracer" and part:IsA("BasePart") then
        if not OriginalColors[part] then
            OriginalColors[part] = {
                Color = part.Color,
                Material = part.Material
            }
        end
        part.Color = BulletTracerColor
        part.Material = Enum.Material.Neon
    end
end

local function RestoreTracer(part)
    local orig = OriginalColors[part]
    if orig then
        part.Color = orig.Color
        part.Material = orig.Material
        OriginalColors[part] = nil
    end
end

VisualTab:CreateToggle({
    Name = "Bullet Tracer",
    CurrentValue = false,
    Flag = "BulletTracerToggle",
    Callback = function(v)
        BulletTracerEnabled = v
        
        if v then
            -- Обрабатываем существующие
            for _, part in pairs(workspace:GetDescendants()) do
                ChangeTracer(part)
            end
            -- Слушаем новые
            if TracerConnection then TracerConnection:Disconnect() end
            TracerConnection = workspace.DescendantAdded:Connect(ChangeTracer)
            Rayfield:Notify({Title = "Bullet Tracer", Content = "Enabled", Duration = 1})
        else
            if TracerConnection then
                TracerConnection:Disconnect()
                TracerConnection = nil
            end
            -- Восстанавливаем
            for part, _ in pairs(OriginalColors) do
                RestoreTracer(part)
            end
            Rayfield:Notify({Title = "Bullet Tracer", Content = "Disabled", Duration = 1})
        end
    end
})

VisualTab:CreateColorPicker({
    Name = "Tracer Color",
