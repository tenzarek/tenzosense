-- Функция обновления отображения кнопок
local function UpdateKeybindDisplay()
    if not KeybindIndicatorEnabled or not KeybindIndicatorGui then return end
    
    local mainFrame = KeybindIndicatorGui:FindFirstChild("MainFrame")
    if not mainFrame then return end
    
    local container = mainFrame:FindFirstChild("ButtonsContainer")
    if not container then return end
    
    -- Удаляем все текущие кнопки
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    local activeCount = 0
    for key, data in pairs(ActiveKeybinds) do
        if data.isPressed then
            activeCount = activeCount + 1
            
            local btn = Instance.new("TextButton")
            btn.Name = key
            btn.Size = UDim2.new(1, -10, 0, 22)
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            btn.BackgroundTransparency = 0.3
