local AuraColor = Color3.fromRGB(0, 255, 0)
local AuraConnection = nil

local function CreateAura()
    if not AuraEnabled then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Удаляем старые части
    for _, part in pairs(AuraParts) do
        if part and part.Parent then
            part:Destroy()
        end
    end
    AuraParts = {}
    
    -- Создаем 8 летающих линий
    for i = 1, 8 do
        local angle = (i / 8) * math.pi * 2
        local part = Instance.new("Part")
        part.Name = "AuraPart"
        part.Size = Vector3.new(0.2, 0.2, 1.5)
        part.Material = Enum.Material.Neon
        part.Color = AuraColor
        part.Anchored = true
        part.CanCollide = false
        part.CastShadow = false
        part.Parent = game.Workspace
        
        AuraParts[i] = {part = part, angle = angle, speed = 0.8}
    end
    
    -- Анимация
    if AuraConnection then AuraConnection:Disconnect() end
    
    local time = 0
    AuraConnection = RunService.RenderStepped:Connect(function(dt)
        if not AuraEnabled then return end
        
        local char = LocalPlayer.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        time = time + dt
        
        for _, data in pairs(AuraParts) do
            if data.part and data.part.Parent then
                local x = math.cos(data.angle + time * 1.5) * 3
                local z = math.sin(data.angle + time * 1.5) * 3
                local y = math.sin(time * data.speed) * 1 + 1.5
                data.part.CFrame = CFrame.new(hrp.Position + Vector3.new(x, y, z))
                data.part.Color = AuraColor
            end
        end
    end)
end

local function ClearAura()
    if AuraConnection then
        AuraConnection:Disconnect()
        AuraConnection = nil
    end
    for _, data in pairs(AuraParts) do
        if data.part and data.part.Parent then
            data.part:Destroy()
        end
    end
    AuraParts = {}
end

