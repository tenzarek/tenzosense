VisualTab:CreateToggle({
    Name = "Keybind Indicator",
    CurrentValue = false,
    Flag = "KeybindIndicatorToggle",
    Callback = function(v)
        KeybindIndicatorEnabled = v
        
        if v then
            -- Создаем GUI
            CreateKeybindIndicator()
            
            -- Регистрируем все кейбинды из Rayfield
            UpdateKeybindsFromRayfield()
            
            -- Отслеживаем изменения кейбиндов в реальном времени
            if KeybindTrackerConnection then KeybindTrackerConnection:Disconnect() end
            
            -- Проверяем каждые 0.5 секунды на изменение кейбиндов
            KeybindTrackerConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if not KeybindIndicatorEnabled then return end
                
                -- Получаем текущие значения кейбиндов
                local currentAimlockKey = GetKeybindValue("AimLockKeybind")
                local currentTeleportKey = GetKeybindValue("TeleportKeybind")
                local currentTpPlayerKey = GetKeybindValue("TeleportToPlayerKeybind")
                
                -- Проверяем Aim Lock
                local aimlockData = ActiveKeybinds[currentAimlockKey]
                if currentAimlockKey and currentAimlockKey ~= "" then
                    if not aimlockData then
                        RegisterKeybind(currentAimlockKey, "Aim Lock")
                    elseif aimlockData.name ~= "Aim Lock" then
                        aimlockData.name = "Aim Lock"
                        UpdateKeybindDisplay()
                    end
                end
                
                -- Проверяем Teleport
                local teleportData = ActiveKeybinds[currentTeleportKey]
                if currentTeleportKey and currentTeleportKey ~= "" then
                    if not teleportData then
                        RegisterKeybind(currentTeleportKey, "TP 500 Up")
                    elseif teleportData.name ~= "TP 500 Up" then
                        teleportData.name = "TP 500 Up"
                        UpdateKeybindDisplay()
                    end
                end
                
                -- Проверяем TP To Player
                local tpPlayerData = ActiveKeybinds[currentTpPlayerKey]
                if currentTpPlayerKey and currentTpPlayerKey ~= "" then
                    if not tpPlayerData then
                        RegisterKeybind(currentTpPlayerKey, "TP To Player")
                    elseif tpPlayerData.name ~= "TP To Player" then
                        tpPlayerData.name = "TP To Player"
                        UpdateKeybindDisplay()
                    end
                end
            end)
            
            Rayfield:Notify({Title = "Keybind Indicator", Content = "Enabled", Duration = 1, Image = "key"})
        else
            -- Отключаем
            if KeybindTrackerConnection then
                KeybindTrackerConnection:Disconnect()
                KeybindTrackerConnection = nil
            end
            
            ClearAllKeybinds()
            
            if KeybindIndicatorGui then
                KeybindIndicatorGui:Destroy()
                KeybindIndicatorGui = nil
            end
            
