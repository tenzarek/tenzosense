    TitleBar.BackgroundTransparency = 0.3
    TitleBar.BorderSizePixel = 0
    TitleBar.Parent = MainFrame
    
    local TitleCorner = Instance.new("UICorner")
    TitleCorner.CornerRadius = UDim.new(0, 8)
    TitleCorner.Parent = TitleBar
    
    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, 0, 1, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = "KEYBINDS"
    TitleLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
    TitleLabel.TextSize = 11
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Center
    TitleLabel.Parent = TitleBar
    
    local ButtonsContainer = Instance.new("Frame")
    ButtonsContainer.Name = "ButtonsContainer"
    ButtonsContainer.Size = UDim2.new(1, -10, 1, -30)
    ButtonsContainer.Position = UDim2.new(0, 5, 0, 28)
    ButtonsContainer.BackgroundTransparency = 1
    ButtonsContainer.Parent = MainFrame
    
    local UILayout = Instance.new("UIListLayout")
    UILayout.SortOrder = Enum.SortOrder.Name
    UILayout.Padding = UDim.new(0, 4)
    UILayout.FillDirection = Enum.FillDirection.Vertical
    UILayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    UILayout.Parent = ButtonsContainer
    
    -- Перетаскивание окна
    local dragging = false
